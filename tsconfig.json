{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "@copyzen/core": ["./packages/core/src"],
      "@copyzen/core/*": ["./packages/core/src/*"],
      "@copyzen/funwheel": ["./packages/funwheel/src"],
      "@copyzen/funwheel/*": ["./packages/funwheel/src/*"],
      "@copyzen/agents": ["./packages/agents/src"],
      "@copyzen/agents/*": ["./packages/agents/src/*"],
      "@copyzen/integrations": ["./packages/integrations/src"],
      "@copyzen/integrations/*": ["./packages/integrations/src/*"],
      "@copyzen/sales-page": ["./packages/sales-page/src"],
      "@copyzen/sales-page/*": ["./packages/sales-page/src/*"]
    }
  },
  "include": [
    "packages/core/src/**/*",
    "packages/agents/src/**/*",
    "packages/integrations/src/**/*",
    "vitest.config.ts",
    "eslint.config.js"
  ],
  "exclude": [
    "node_modules",
    "**/dist/**",
    "packages/funwheel/**",
    "packages/sales-page/**"
  ]
}
