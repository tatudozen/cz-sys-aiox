---
import '../styles/global.css';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="FunWheel — A plataforma de marketing inteligente da CopyZen. Em breve." />
    <meta name="robots" content="index, follow" />
    <title>FunWheel — Em Breve | CopyZen</title>
    <link rel="canonical" href="https://fw.copyzen.com.br/" />
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen flex flex-col">
    <!-- Header -->
    <header class="w-full py-6 px-4 sm:px-8">
      <div class="max-w-4xl mx-auto flex items-center gap-3">
        <!-- Logo CopyZen placeholder -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="36"
          height="36"
          viewBox="0 0 36 36"
          fill="none"
          aria-label="CopyZen logo"
          role="img"
        >
          <rect width="36" height="36" rx="8" fill="#0F172A" />
          <text
            x="50%"
            y="55%"
            dominant-baseline="middle"
            text-anchor="middle"
            fill="white"
            font-family="sans-serif"
            font-size="14"
            font-weight="bold"
          >CZ</text>
        </svg>
        <span class="text-xl font-semibold tracking-tight">CopyZen</span>
      </div>
    </header>

    <!-- Main -->
    <main class="flex-1 flex items-center justify-center px-4 sm:px-8 py-12 sm:py-20">
      <div class="max-w-2xl mx-auto text-center">
        <!-- Badge -->
        <span class="inline-block bg-indigo-100 text-indigo-700 text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-8">
          Em Breve
        </span>

        <!-- Headline -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-gray-900 mb-6">
          FunWheel — Em Breve
        </h1>

        <!-- Subtitle -->
        <p class="text-lg sm:text-xl text-gray-600 leading-relaxed mb-10 max-w-xl mx-auto">
          A plataforma de marketing inteligente que combina copywriting assistido por IA
          com automação de campanhas. Atração, Retenção e Transformação em um só lugar.
        </p>

        <!-- CTA placeholder -->
        <p class="text-sm text-gray-400">
          Notificações em breve — fique ligado.
        </p>
      </div>
    </main>

    <!-- Footer -->
    <footer class="w-full py-6 px-4 sm:px-8 border-t border-gray-200">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-sm text-gray-500">
          Powered by <strong class="text-gray-700">CopyZen</strong>
        </p>
      </div>
    </footer>
  </body>
</html>
