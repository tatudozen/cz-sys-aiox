---
/**
 * Hero — Brand-aware hero section with gradient background
 * Story 5.1 — AC-3
 */

interface Props {
  headline: string;
  subheadline?: string;
  imageUrl?: string;
  imageAlt?: string;
  /** If true, uses brand gradient as background */
  gradientBg?: boolean;
}

const {
  headline,
  subheadline,
  imageUrl,
  imageAlt = 'Hero image',
  gradientBg = true,
} = Astro.props;
---

<section
  class:list={[
    'w-full px-4 sm:px-8 py-16 sm:py-24 lg:py-32',
    gradientBg ? 'hero-gradient text-white' : 'bg-white',
  ]}
  aria-label="Hero section"
>
  <div class="max-w-4xl mx-auto text-center">
    {imageUrl && (
      <div class="mb-8 flex justify-center">
        <img
          src={imageUrl}
          alt={imageAlt}
          class="rounded-2xl shadow-2xl max-h-64 object-cover w-full max-w-2xl"
          loading="eager"
          width="800"
          height="400"
        />
      </div>
    )}

    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight mb-4 sm:mb-6">
      {headline}
    </h1>

    {subheadline && (
      <p class="text-lg sm:text-xl leading-relaxed max-w-2xl mx-auto opacity-90">
        {subheadline}
      </p>
    )}

    <slot />
  </div>
</section>

<style>
  .hero-gradient {
    background: var(--brand-gradient);
  }
</style>
