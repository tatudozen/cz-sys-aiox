---
/**
 * Footer — Brand-aware footer component
 * Story 5.1 — AC-3
 */

interface Props {
  companyName?: string;
  year?: number;
  links?: Array<{ label: string; href: string }>;
}

const {
  companyName = 'CopyZen',
  year = new Date().getFullYear(),
  links = [],
} = Astro.props;
---

<footer class="w-full px-4 sm:px-8 py-8 footer-bg border-t border-opacity-10 mt-auto">
  <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-sm text-center sm:text-left footer-text">
      &copy; {year} <strong>{companyName}</strong> — Todos os direitos reservados.
    </p>

    {links.length > 0 && (
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap gap-4 justify-center">
          {links.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm footer-link hover:underline transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )}

    <p class="text-xs footer-powered">
      Powered by <strong>CopyZen</strong>
    </p>
  </div>
</footer>

<style>
  .footer-bg {
    background-color: color-mix(in srgb, var(--brand-primary) 5%, #ffffff);
    border-color: var(--brand-primary);
  }
  .footer-text {
    color: var(--brand-text);
    opacity: 0.7;
  }
  .footer-link {
    color: var(--brand-primary);
  }
  .footer-powered {
    color: var(--brand-text);
    opacity: 0.4;
  }
</style>
