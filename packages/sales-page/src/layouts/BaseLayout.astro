---
/**
 * BaseLayout for Sales Page
 * Story 6.1 — mobile-first, brand CSS vars, scroll progress, sticky CTA
 */
import { generateSalesThemeCSS, googleFontsUrl } from '../lib/theme';
import type { SalesPageBrand } from '../lib/theme';

interface Props {
  title: string;
  description?: string;
  brand?: SalesPageBrand;
  ctaText?: string;
  ctaUrl?: string;
  ogImage?: string;
}

const {
  title,
  description = '',
  brand,
  ctaText = 'Quero Acesso Agora →',
  ctaUrl = '#oferta',
  ogImage,
} = Astro.props;

const cssVars = generateSalesThemeCSS(brand);
const fontsUrl = googleFontsUrl(brand);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={fontsUrl} />

    <!-- Brand CSS variables -->
    <style set:html={cssVars} />

    <!-- Base styles -->
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: var(--sp-body-font);
        background-color: var(--sp-bg);
        color: var(--sp-text);
        line-height: 1.6;
      }
      h1, h2, h3, h4 {
        font-family: var(--sp-heading-font);
        line-height: 1.2;
      }

      /* Scroll progress bar */
      #sp-progress {
        position: fixed;
        top: 0;
        left: 0;
        height: 3px;
        width: 0%;
        background: var(--sp-gradient);
        z-index: 9999;
        transition: width 0.1s linear;
      }

      /* Sticky CTA (mobile) */
      #sp-sticky-cta {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 999;
        padding: 12px 16px;
        background: rgba(255, 255, 255, 0.97);
        border-top: 1px solid #e2e8f0;
        transform: translateY(100%);
        transition: transform 0.3s ease;
      }
      #sp-sticky-cta.visible {
        transform: translateY(0);
      }
      #sp-sticky-cta a {
        display: block;
        width: 100%;
        padding: 16px;
        background: var(--sp-gradient);
        color: #fff;
        font-family: var(--sp-heading-font);
        font-weight: 700;
        font-size: 1.1rem;
        text-align: center;
        text-decoration: none;
        border-radius: 12px;
      }
      @media (min-width: 768px) {
        #sp-sticky-cta { display: none; }
      }
    </style>
  </head>
  <body>
    <!-- Scroll progress -->
    <div id="sp-progress" aria-hidden="true"></div>

    <!-- Page content -->
    <main>
      <slot />
    </main>

    <!-- Sticky CTA (mobile only) -->
    <div id="sp-sticky-cta" aria-label="CTA">
      <a href={ctaUrl}>{ctaText}</a>
    </div>

    <!-- Scroll progress + sticky CTA logic -->
    <script>
      const progressBar = document.getElementById('sp-progress');
      const stickyCta = document.getElementById('sp-sticky-cta');
      let ticking = false;

      function onScroll() {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          const scrolled = window.scrollY;
          const total = document.documentElement.scrollHeight - window.innerHeight;
          const pct = total > 0 ? (scrolled / total) * 100 : 0;

          if (progressBar) progressBar.style.width = `${pct}%`;

          // Show sticky CTA after scrolling 20% of the page
          if (stickyCta) {
            if (pct > 20) {
              stickyCta.classList.add('visible');
            } else {
              stickyCta.classList.remove('visible');
            }
          }

          ticking = false;
        });
      }

      window.addEventListener('scroll', onScroll, { passive: true });
    </script>
  </body>
</html>
