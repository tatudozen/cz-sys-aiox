---
/** Benefits section — lista de benefícios. Story 6.1 AC-2 */
interface Benefit { icon?: string; title: string; description: string; }
interface Props {
  title?: string;
  subtitle?: string;
  benefits?: Benefit[];
}
const {
  title = 'O que você vai conquistar',
  subtitle,
  benefits = [],
} = Astro.props;
---

<section class="sp-benefits" aria-label="Benefícios">
  <div class="sp-container">
    <h2 class="sp-section-title">{title}</h2>
    {subtitle && <p class="sp-section-subtitle">{subtitle}</p>}

    <ul class="sp-benefits-grid" role="list">
      {benefits.map(b => (
        <li class="sp-benefit-card">
          {b.icon && <span class="sp-benefit-icon" aria-hidden="true">{b.icon}</span>}
          <h3 class="sp-benefit-title">{b.title}</h3>
          <p class="sp-benefit-desc">{b.description}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .sp-benefits {
    background: #f8fafc;
    padding: 80px 0;
    text-align: center;
  }
  .sp-container { max-width: 1000px; margin: 0 auto; padding: 0 20px; }
  .sp-section-title {
    font-size: clamp(1.5rem, 3.5vw, 2.4rem);
    font-weight: 800;
    color: var(--sp-primary);
    margin-bottom: 12px;
  }
  .sp-section-subtitle {
    font-size: 1.05rem;
    opacity: 0.7;
    margin-bottom: 48px;
  }
  .sp-benefits-grid {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin: 0;
  }
  @media (min-width: 560px) { .sp-benefits-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .sp-benefits-grid { grid-template-columns: repeat(3, 1fr); } }
  .sp-benefit-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 28px 24px;
    text-align: left;
    transition: box-shadow 0.2s;
  }
  .sp-benefit-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.07); }
  .sp-benefit-icon { font-size: 2rem; display: block; margin-bottom: 12px; }
  .sp-benefit-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--sp-primary);
    margin-bottom: 8px;
  }
  .sp-benefit-desc { font-size: 0.92rem; opacity: 0.7; line-height: 1.55; }
</style>
