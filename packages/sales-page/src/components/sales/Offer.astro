---
/** Offer section — o que está incluído + preço. Story 6.1 AC-2, AC-4 */
interface OfferItem { icon?: string; text: string; }
interface Props {
  id?: string;
  title?: string;
  subtitle?: string;
  price?: string;
  priceOriginal?: string;
  pricePeriod?: string;
  items?: OfferItem[];
  ctaText?: string;
  ctaUrl?: string;
  badgeText?: string;
}
const {
  id = 'oferta',
  title = 'O Que Você Recebe',
  subtitle,
  price = 'R$ 997',
  priceOriginal,
  pricePeriod = 'pagamento único',
  items = [],
  ctaText = 'Quero Acesso Agora →',
  ctaUrl = '#',
  badgeText = 'Oferta por tempo limitado',
} = Astro.props;
---

<section {id} class="sp-offer" aria-label="Oferta">
  <div class="sp-container">
    <h2 class="sp-section-title">{title}</h2>
    {subtitle && <p class="sp-section-subtitle">{subtitle}</p>}

    <div class="sp-offer-card">
      {badgeText && <div class="sp-offer-badge">{badgeText}</div>}

      {items.length > 0 && (
        <ul class="sp-offer-items" role="list">
          {items.map(item => (
            <li class="sp-offer-item">
              <span class="sp-offer-check" aria-hidden="true">{item.icon ?? '✓'}</span>
              <span>{item.text}</span>
            </li>
          ))}
        </ul>
      )}

      <div class="sp-price-block">
        {priceOriginal && (
          <p class="sp-price-original" aria-label="De">
            <s>De {priceOriginal}</s>
          </p>
        )}
        <p class="sp-price" aria-label="Por">{price}</p>
        <p class="sp-price-period">{pricePeriod}</p>
      </div>

      <a href={ctaUrl} class="sp-offer-cta">{ctaText}</a>
    </div>
  </div>
</section>

<style>
  .sp-offer { background: #f8fafc; padding: 80px 0; text-align: center; }
  .sp-container { max-width: 860px; margin: 0 auto; padding: 0 20px; }
  .sp-section-title {
    font-size: clamp(1.5rem, 3.5vw, 2.4rem);
    font-weight: 800;
    color: var(--sp-primary);
    margin-bottom: 12px;
  }
  .sp-section-subtitle { font-size: 1.05rem; opacity: 0.7; margin-bottom: 40px; }
  .sp-offer-card {
    background: #fff;
    border: 2px solid var(--sp-secondary);
    border-radius: 24px;
    padding: 40px 32px;
    max-width: 560px;
    margin: 0 auto;
  }
  .sp-offer-badge {
    display: inline-block;
    background: var(--sp-gradient);
    color: #fff;
    border-radius: 9999px;
    padding: 6px 18px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    margin-bottom: 24px;
  }
  .sp-offer-items { list-style: none; margin-bottom: 32px; text-align: left; }
  .sp-offer-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid #f1f5f9;
    font-size: 0.95rem;
  }
  .sp-offer-item:last-child { border-bottom: none; }
  .sp-offer-check { color: var(--sp-secondary); font-weight: 700; flex-shrink: 0; }
  .sp-price-block { margin-bottom: 28px; }
  .sp-price-original { font-size: 1rem; color: #94a3b8; margin-bottom: 4px; }
  .sp-price {
    font-size: 3rem;
    font-weight: 800;
    color: var(--sp-primary);
    font-family: var(--sp-heading-font);
    line-height: 1;
  }
  .sp-price-period { font-size: 0.85rem; opacity: 0.6; margin-top: 4px; }
  .sp-offer-cta {
    display: block;
    width: 100%;
    padding: 18px;
    background: var(--sp-gradient);
    color: #fff;
    font-family: var(--sp-heading-font);
    font-weight: 700;
    font-size: 1.15rem;
    border-radius: 14px;
    text-decoration: none;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .sp-offer-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
  }
</style>
