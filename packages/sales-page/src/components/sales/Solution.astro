---
/** Solution section — apresenta a solução. Story 6.1 AC-2 */
interface Props {
  title?: string;
  body?: string;
  highlights?: string[];
  ctaText?: string;
  ctaUrl?: string;
}
const {
  title = 'A Solução que Você Estava Esperando',
  body,
  highlights = [],
  ctaText = 'Quero Saber Mais →',
  ctaUrl = '#oferta',
} = Astro.props;
---

<section class="sp-solution" aria-label="Solução">
  <div class="sp-container">
    <div class="sp-solution__inner">
      <h2 class="sp-section-title">{title}</h2>
      {body && <p class="sp-section-body">{body}</p>}

      {highlights.length > 0 && (
        <ul class="sp-highlight-list" role="list">
          {highlights.map(h => (
            <li class="sp-highlight-item">
              <span class="sp-check" aria-hidden="true">✓</span>
              <span>{h}</span>
            </li>
          ))}
        </ul>
      )}

      <a href={ctaUrl} class="sp-btn-solution">{ctaText}</a>
    </div>
  </div>
</section>

<style>
  .sp-solution {
    background: #fff;
    padding: 80px 0;
    text-align: center;
  }
  .sp-container { max-width: 860px; margin: 0 auto; padding: 0 20px; }
  .sp-section-title {
    font-size: clamp(1.5rem, 3.5vw, 2.4rem);
    font-weight: 800;
    color: var(--sp-primary);
    margin-bottom: 16px;
  }
  .sp-section-body {
    font-size: 1.05rem;
    opacity: 0.75;
    margin-bottom: 28px;
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
  }
  .sp-solution__inner { max-width: 640px; margin: 0 auto; }
  .sp-highlight-list {
    list-style: none;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 32px;
  }
  .sp-highlight-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 1rem;
  }
  .sp-check {
    color: var(--sp-secondary);
    font-weight: 700;
    font-size: 1.1rem;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .sp-btn-solution {
    display: inline-block;
    padding: 14px 36px;
    background: var(--sp-gradient);
    color: #fff;
    font-family: var(--sp-heading-font);
    font-weight: 700;
    font-size: 1.05rem;
    border-radius: 12px;
    text-decoration: none;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .sp-btn-solution:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.15);
  }
</style>
