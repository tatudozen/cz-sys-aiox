            "index": 0
          }
        ]
      ]
    },
    "Validate: Required Fields": {
      "main": [
        [
          {
            "node": "Supabase: INSERT briefing",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Response: Validation Error 400",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Supabase: INSERT briefing": {
      "main": [
        [
          {
            "node": "Response: Success 201",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner",
    "errorWorkflow": ""
